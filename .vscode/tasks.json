        {
            "label": "Flash ESP32-S3 via JTAG (RPi)",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/tools/flash-esp32s3-jtag.sh"
            ],
            "group": "build",
            "problemMatcher": [],
