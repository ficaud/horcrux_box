{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (esp32s3_devkitc/procpu)",
            "type": "shell",
            "command": "west",
            "args": [
                "build",
                "-b",
                "esp32s3_devkitc/esp32s3/procpu",
                "-d",
                "build",
                "."
            ],
            "options": {
                "env": {
                    "ZEPHYR_BASE": "${workspaceFolder}/zephyr",
                    "ZEPHYR_SDK_INSTALL_DIR": "/opt/zephyr-sdk"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "clear": true
            }
        },
        {
            "label": "Build (esp32_wroom_32/procpu)",
            "type": "shell",
            "command": "west",
