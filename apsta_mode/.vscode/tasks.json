{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (esp32s3_devkitc/procpu)",
            "type": "shell",
            "command": "west build -b esp32s3_devkitc/esp32s3/procpu -d build .",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "clear": true
            }
        },
        {
            "label": "Pristine Build (esp32s3_devkitc/procpu)",
            "type": "shell",
            "command": "west build -b esp32s3_devkitc/esp32s3/procpu -p always -d build .",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "clear": true
            }
        }
    ]
}